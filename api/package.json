    "dotenv": "^16.6.1",
    "hono": "^4.4.0",
    "ics": "^3.10.0",
    "pg": "^8.20.0",
    "prisma": "^7.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.0"
  }
