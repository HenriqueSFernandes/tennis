generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Better Auth tables
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  
  riotintoAccounts RiotintoAccount[]
  profile         UserProfile?

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// App tables - Riotinto integration
model RiotintoAccount {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  username          String
  displayName       String    @map("display_name")
  phone             String
  encryptedPassword String    @map("encrypted_password")
  salt              String
  iv                String
  createdAt         DateTime  @default(now()) @map("created_at")

  sessionCache RiotintoSession?
  favorites    RiotintoFavorite[]
  bookingCache BookingCache[]

  @@unique([userId, username])
  @@map("riotinto_accounts")
}

model RiotintoSession {
  accountId String  @id @map("account_id")
  cookies   String
  csrfToken String  @map("csrf_token")
  userId    String  @map("user_id")
  cachedAt  BigInt  @map("cached_at")

  account RiotintoAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("riotinto_sessions")
}

model RiotintoFavorite {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  courtId   Int      @map("court_id")
  dayOfWeek Int      @map("day_of_week")
  time      String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  account RiotintoAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, courtId, dayOfWeek, time])
  @@map("riotinto_favorites")
}

// ── Social features ────────────────────────────────────────────────────────────

model UserProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  username              String   @unique
  showBookingsToFriends Boolean  @default(true) @map("show_bookings_to_friends")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentFriendRequests     FriendRequest[] @relation("SentRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedRequests")
  friendshipsAsRequester Friendship[]    @relation("FriendshipsAsRequester")
  friendshipsAsReceiver  Friendship[]    @relation("FriendshipsAsReceiver")

  @@map("user_profiles")
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")

  sender   UserProfile @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver UserProfile @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("friend_requests")
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  friendId  String   @map("friend_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   UserProfile @relation("FriendshipsAsRequester", fields: [userId], references: [id], onDelete: Cascade)
  friend UserProfile @relation("FriendshipsAsReceiver", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@map("friendships")
}

model BookingCache {
  id                String   @id @default(cuid())
  riotintoAccountId String   @map("riotinto_account_id")
  courtId           Int      @map("court_id")
  date              String
  dayIndex          Int      @map("day_index")
  turno             String
  hora              String
  time              String
  semana            Int
  status            String   @default("booked")
  lastSynced        DateTime @default(now()) @map("last_synced")

  account RiotintoAccount @relation(fields: [riotintoAccountId], references: [id], onDelete: Cascade)

  @@unique([riotintoAccountId, courtId, date, hora])
  @@map("booking_cache")
}
